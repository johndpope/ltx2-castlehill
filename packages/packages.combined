add_multiline(slide, left_x + Inches(0.3), Inches(2.1), Inches(4.9), Inches(4.5), [
    ("z = \u03bc + \u03c3 \u00b7 \u03b5,  \u03b5 ~ N(0, I)", ACCENT_RED, True, 20),
    ("", WHITE, False, 8),
